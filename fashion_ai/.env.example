# ============================================================================
# HUEIQ RECOMMENDATION ENGINE - EXAMPLE ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Boss API Configuration
BOSS_API_URL=https://your-api-url.azurecontainerapps.io
BOSS_TOKEN=your_jwt_token_here

# MongoDB Configuration
MONGO_URI=mongodb://username:password@host:port/database_name
DATABASE_NAME=your_database_name

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=True

# Cache Settings
CACHE_TTL=3600
MAX_CANDIDATES=500
DEFAULT_TOP_K=10

# Feature Dimensions
EMBEDDING_DIM=128
VISUAL_DIM=512